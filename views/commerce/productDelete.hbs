<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card shadow border-danger text-center">
            
            <div class="card-header bg-danger text-white py-3">
                <h4 class="mb-0"><i class="fas fa-exclamation-triangle me-2"></i> Confirmar Eliminación</h4>
            </div>
            
            <div class="card-body p-5">
                <i class="fas fa-trash-alt text-danger mb-4" style="font-size: 3.5rem;"></i>
                
                <h4 class="card-title fw-bold">¿Estás seguro de eliminar "{{product.name}}"?</h4>
                <p class="text-muted mt-2">Esta acción eliminará el producto de tu catálogo permanentemente y no se puede deshacer.</p>
                
                <form action="/comercio/producto/eliminar/{{product.stringId}}" method="POST" class="mt-4">
                    <div class="d-flex justify-content-center gap-3">
                        <a href="/comercio/productos" class="btn btn-outline-secondary px-4 py-2">Cancelar</a>
                        <button type="submit" class="btn btn-danger px-4 py-2">Sí, eliminar producto</button>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>