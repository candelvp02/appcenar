<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow border-danger">
            <div class="card-header bg-danger text-white">
                <h4 class="mb-0"><i class="fas fa-exclamation-triangle"></i> Confirmar eliminación</h4>
            </div>
            <div class="card-body">
                <p>¿Está seguro que desea eliminar la categoría <strong>{{category.name}}</strong>?</p>
                <p class="text-danger">Advertencia: Se eliminarán <strong>{{productCount}}</strong> productos de esta categoría.</p>
<form action="/comercio/categoria/eliminar/{{category.stringId}}" method="POST">
                    <button type="submit" class="btn btn-danger">Sí, eliminar</button>
                    <a href="/comercio/categorias" class="btn btn-secondary">Cancelar</a>
                </form>
            </div>
        </div>
    </div>
</div>