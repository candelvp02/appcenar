<a href="/comercio/home" class="back-btn btn btn-outline-secondary mb-3"><i class="bi bi-arrow-left"></i> Volver a Pedidos</a>

<div style="max-width:600px;margin:0 auto;">
  <div class="order-detail-header text-center mb-4">
    {{#if order.commerceId.logo}}
      <img src="/uploads/{{order.commerceId.logo}}" class="order-detail-logo mb-2" style="width: 80px; height: 80px; object-fit: cover; border-radius: 50%;" />
    {{/if}}
    <div class="order-detail-name fs-4 fw-bold">{{order.commerceId.name}}</div>
    <span class="badge bg-{{statusClass order.status}} mt-2 px-3 py-2" style="font-size:0.85rem;">{{statusLabel order.status}}</span>
    <div class="order-detail-date mt-2 text-muted">{{formatDate order.createdAt}}</div>
  </div>

  {{#ifCond order.status '===' 'pending'}}
    <div class="card mb-4 border-danger shadow-sm">
      <div class="card-body">
        <h5 class="card-title text-danger mb-3 fw-bold"><i class="bi bi-motorcycle me-2"></i> Asignar Delivery</h5>
        
        {{#if @root.error}}
            <div class="alert alert-danger"><i class="bi bi-exclamation-octagon me-2"></i>{{@root.error}}</div>
        {{/if}}

        {{#if @root.deliveries}}
          <form action="/comercio/pedido/{{@root.order.stringId}}/asignar" method="POST">
            <div class="mb-3">
              <select name="deliveryId" class="form-select" required>
                <option value="" disabled selected>Selecciona un delivery disponible...</option>
                {{#each @root.deliveries}}
                  <option value="{{this.stringId}}">{{this.firstName}} {{this.lastName}}</option>
                {{/each}}
              </select>
            </div>
            <button type="submit" class="btn btn-danger w-100 py-2 fw-bold">
              <i class="bi bi-person-check me-2"></i>Asignar y pasar a "En proceso"
            </button>
          </form>
        {{else}}
          <div class="alert alert-warning mb-0 text-center">
              <i class="bi bi-exclamation-triangle-fill fs-3 d-block mb-2 text-warning"></i>
              <strong>No hay deliveries disponibles en este momento.</strong><br>
              <span class="text-muted small">Por favor, intente de nuevo más tarde.</span>
          </div>
        {{/if}}
      </div>
    </div>
  {{/ifCond}}

  <div class="card mb-3 shadow-sm">
    <div class="card-body">
      <div style="font-weight:700;margin-bottom:1rem;" class="fs-5">El Pedido</div>
      
      <div class="order-items-list">
        {{#each order.items}}
          <div class="order-product-item d-flex align-items-center justify-content-between border-bottom py-2">
            <div class="d-flex align-items-center gap-3">
              {{#if productImage}}
                  <img src="/uploads/{{productImage}}" class="order-product-img rounded" style="width: 50px; height: 50px; object-fit: cover;" />
              {{else}}
                  <div class="order-product-img-placeholder bg-light rounded d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                    <i class="bi bi-image text-muted"></i>
                  </div>
              {{/if}}
              <span class="order-product-name fw-medium">{{productName}}</span>
            </div>
            <span class="order-product-price text-muted">RD$ {{productPrice}}</span>
          </div>
        {{/each}}
      </div>
      
      <div class="order-total-row d-flex justify-content-between align-items-center mt-3 pt-3 border-top">
        <span class="fw-bold fs-5">Total</span>
        <span class="fw-bold text-danger fs-5">RD$ {{order.total}}</span>
      </div>
    </div>
  </div>
</div>