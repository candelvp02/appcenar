<a href="/comercio/home" class="back-btn"><i class="bi bi-arrow-left"></i> Volver a Pedidos</a>

<div style="max-width:600px;margin:0 auto;">
  <div class="order-detail-header">
    {{#if order.commerceId.logo}}
      <img src="/uploads/{{order.commerceId.logo}}" class="order-detail-logo" />
    {{/if}}
    <div class="order-detail-name">{{order.commerceId.name}}</div>
    <span class="badge bg-{{statusClass order.status}} mt-2" style="font-size:0.85rem;">{{statusLabel order.status}}</span>
    <div class="order-detail-date">{{formatDate order.createdAt}}</div>
  </div>

  {{#ifCond order.status '===' 'pending'}}
    <div class="card mb-3 border-danger shadow-sm">
      <div class="card-body">
        <h5 class="card-title text-danger mb-3"><i class="bi bi-motorcycle"></i> Asignar Delivery</h5>
<form action="/comercio/pedido/{{@root.order._id}}/asignar" method="POST">
          <div class="mb-3">
            <select name="deliveryId" class="form-select" required>
  <option value="">Selecciona un delivery disponible...</option>
  {{#each @root.deliveries}}
    <option value="{{_id}}">{{firstName}} {{lastName}}</option>
  {{/each}}
</select>
          </div>
          <button type="submit" class="btn btn-danger w-100 py-2">
            <i class="bi bi-person-check me-2"></i>Asignar y pasar a "En proceso"
          </button>
        </form>
      </div>
    </div>
  {{/ifCond}}

  <div class="card mb-3 shadow-sm">
    <div class="card-body">
      <div style="font-weight:700;margin-bottom:1rem;">El Pedido</div>
      <div class="order-items-list">
        {{#each order.items}}
          <div class="order-product-item">
            {{#if productImage}}
                <img src="/uploads/{{productImage}}" class="order-product-img" />
            {{else}}
                <div class="order-product-img-placeholder"><i class="bi bi-image"></i></div>
            {{/if}}
            <span class="order-product-name">{{productName}}</span>
            <span class="order-product-price">RD$ {{productPrice}}</span>
          </div>
        {{/each}}
      </div>
      <div class="order-total-row mt-3 pt-3 border-top">
        <span class="fw-bold">Total</span><span class="fw-bold text-danger">RD$ {{order.total}}</span>
      </div>
    </div>
  </div>
</div>
