<a href="/commerce/home" class="back-btn"><i class="bi bi-arrow-left"></i> Volver</a>
<div style="max-width:600px;margin:0 auto;">
  <div class="order-detail-header">
    {{#if commerce.logo}}
      <img src="{{commerce.logo}}" class="order-detail-logo" />
    {{/if}}
    <div class="order-detail-name">{{commerce.name}}</div>
    <span class="badge bg-{{statusClass order.status}} mt-2" style="font-size:0.85rem;">{{statusLabel order.status}}</span>
    <div class="order-detail-date">{{formatDate order.orderedAt}}</div>
  </div>

  {{#ifCond order.status '===' 'pending'}}
    <form action="/commerce/orders/{{order._id}}/assign-delivery" method="POST" class="d-grid mb-3">
      <button type="submit" class="btn btn-danger py-2">
        <i class="bi bi-person-check me-2"></i>Asignar Delivery
      </button>
    </form>
  {{/ifCond}}

  <div class="card mb-3">
    <div class="card-body">
      <div style="font-weight:700;margin-bottom:1rem;">El Pedido</div>
      <div class="order-items-list">
        {{#each order.items}}
          <div class="order-product-item">
            {{#if image}}<img src="{{image}}" class="order-product-img" />
            {{else}}<div class="order-product-img-placeholder"><i class="bi bi-image"></i></div>{{/if}}
            <span class="order-product-name">{{name}}</span>
            <span class="order-product-price">RD$ {{price}}</span>
          </div>
        {{/each}}
      </div>
      <div class="order-total-row mt-3">
        <span>Total</span><span>RD$ {{order.total}}</span>
      </div>
    </div>
  </div>
</div>
