<div class="container">
    <h2 class="mb-4">Pedidos de mi comercio</h2>
    
    {{#each orders}}
    <div class="card mb-3" onclick="window.location.href='/comercio/pedido/{{this._id}}'" style="cursor:pointer;">
        <div class="card-body">
            <div class="row align-items-center">
                <div class="col-md-3">
                    <h5>Pedido #{{this._id}}</h5>
                    <span class="badge status-{{this.status}}">{{statusLabel this.status}}</span>
                </div>
                <div class="col-md-3">
                    <p class="mb-0">Cliente: {{this.clientId.firstName}} {{this.clientId.lastName}}</p>
                    <small class="text-muted">{{this.items.length}} producto(s)</small>
                </div>
                <div class="col-md-3">
                    <p class="mb-0 fw-bold">Total: RD$ {{this.total}}</p>
                </div>
                <div class="col-md-2">
                    <small class="text-muted">{{formatDate this.createdAt}}</small>
                </div>
                <div class="col-md-1">
                    <i class="fas fa-chevron-right"></i>
                </div>
            </div>
        </div>
    </div>
    {{else}}
    <div class="alert alert-info">No hay pedidos para este comercio</div>
    {{/each}}
</div>