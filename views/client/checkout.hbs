<a href="/cliente/catalogo/{{commerce._id}}" class="btn btn-secondary mb-3"><i class="fas fa-arrow-left"></i> Volver al Catálogo</a>

<h2>Confirmar Pedido</h2>

<form action="/cliente/pedido/crear" method="POST">
  <div class="mb-3">
    <label class="form-label fw-bold">Selecciona tu dirección</label>
    
    {{#if addresses.length}}
      {{#each addresses}}
        <div class="form-check">
          <input class="form-check-input address-radio" type="radio" name="addressId" value="{{_id}}" required>
          <label class="form-check-label">{{name}} - {{description}}</label>
        </div>
      {{/each}}
      <button type="submit" id="btn-pedir" class="btn btn-success mt-3" disabled>Realizar pedido</button>
      
      <script>
        // JS simple para habilitar el botón al hacer clic en una dirección
        document.querySelectorAll('.address-radio').forEach(radio => {
          radio.addEventListener('change', () => {
            document.getElementById('btn-pedir').disabled = false;
          });
        });
      </script>
    {{else}}
      <div class="alert alert-warning mt-2">
        No tienes direcciones registradas. <a href="/cliente/direccion/crear">Crea una nueva dirección aquí</a> para continuar.
      </div>
    {{/if}}
  </div>
</form>

<div class="mt-4 p-3 border rounded shadow-sm">
  <div class="text-center mb-3 border-bottom pb-3">
    {{#if commerce.logo}}
      <img src="/uploads/{{commerce.logo}}" width="60" height="60" style="border-radius:50%; object-fit:cover;">
    {{/if}}
    <h4 class="mt-2">{{commerce.name}}</h4>
  </div>

  <h5>Resumen del pedido</h5>
  
  {{#each cart}}
    <div class="d-flex justify-content-between mb-1">
      <span>{{name}}</span> 
      <span class="fw-bold">RD$ {{price}}</span>
    </div>
  {{/each}}
  <hr>
  
  <div class="d-flex justify-content-between text-muted">
    <span>Subtotal:</span> <span>RD$ {{subtotal}}</span>
  </div>
  <div class="d-flex justify-content-between text-muted mb-2">
    <span>ITBIS ({{itbisPercent}}%):</span> <span>RD$ {{itbis}}</span>
  </div>
  <div class="d-flex justify-content-between border-top pt-2">
    <h5 class="mb-0">Total:</h5> <h5 class="text-danger mb-0">RD$ {{total}}</h5>
  </div>
</div>