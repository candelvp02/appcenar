<a href="javascript:history.back()" class="btn btn-secondary mb-3"><i class="fas fa-arrow-left"></i> Volver</a>

<h2>Confirmar Pedido</h2>

<form action="/cliente/pedido/crear" method="POST">
  <div class="mb-3">
    <label class="form-label fw-bold">Selecciona tu dirección</label>
    {{#each addresses}}
      <div class="form-check">
        <input class="form-check-input" type="radio" name="addressId" value="{{_id}}" required>
        <label class="form-check-label">{{name}} - {{description}}</label>
      </div>
    {{/each}}
  </div>
  <button type="submit" class="btn btn-success">Realizar pedido</button>
</form>

<div class="mt-4 p-3 border rounded">
  <h5>Resumen del pedido</h5>
  {{#each cart}}
    <div class="d-flex justify-content-between">{{name}} <span>RD$ {{price}}</span></div>
  {{/each}}
  <hr>
  <div>Subtotal: RD$ {{subtotal}}</div>
  <div>ITBIS ({{itbisPercent}}%): RD$ {{itbis}}</div>
  <h5>Total: RD$ {{total}}</h5>
</div>