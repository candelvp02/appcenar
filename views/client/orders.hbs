<div class="page-header">
  <h1 class="page-title"><i class="bi bi-bag"></i> Mis Pedidos</h1>
</div>

<div class="order-list">
  {{#each orders}}
    <a href="/client/orders/{{_id}}" class="order-item {{status}}">
      {{#if commerce.logo}}
        <img src="{{commerce.logo}}" style="width:48px;height:48px;border-radius:12px;object-fit:cover;flex-shrink:0;" />
      {{else}}
        <div style="width:48px;height:48px;border-radius:12px;background:#f3f4f6;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <i class="bi bi-shop" style="color:#9ca3af;"></i>
        </div>
      {{/if}}
      <div class="order-meta">
        <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.25rem;">
          <span class="badge bg-{{statusClass status}}">{{statusLabel status}}</span>
          <span style="color:#9ca3af;font-size:0.78rem;">{{formatDate orderedAt}}</span>
        </div>
        <div class="order-commerce-name">{{commerce.name}}</div>
        <div class="order-info">RD$ {{total}} &bull; {{itemCount}} producto(s)</div>
      </div>
      <i class="bi bi-chevron-right" style="color:#d1d5db;"></i>
    </a>
  {{else}}
    <div class="empty-state">
      <i class="bi bi-bag-x"></i>
      <p>No tienes pedidos aún.<br><a href="/client/home" style="color:var(--orange);">¡Haz tu primer pedido!</a></p>
    </div>
  {{/each}}
</div>