<a href="javascript:history.back()" class="btn btn-secondary mb-3">Volver a comercios</a>

<div class="d-flex align-items-center gap-3 mb-4">
  {{#if commerce.logo}}
    <img src="/uploads/{{commerce.logo}}" width="60" height="60" class="rounded-circle">
  {{/if}}
  <h2>{{commerce.name}}</h2>
</div>

{{#each categories}}
  <div class="mb-4">
    <h4 class="border-bottom pb-2">{{name}}</h4>
    <div class="row">
      {{#each products}}
      <div class="col-md-6 mb-3">
        <div class="card">
          <div class="row g-0">
            <div class="col-md-4">
              {{#if image}}
                <img src="/uploads/{{image}}" class="img-fluid rounded-start" style="height: 120px; object-fit: cover; width: 100%;">
              {{else}}
                <div class="bg-light text-center p-3" style="height: 120px;"><i class="fas fa-image fa-2x mt-3"></i></div>
              {{/if}}
            </div>
            <div class="col-md-8">
              <div class="card-body">
                <h5 class="card-title">{{name}}</h5>
                <p class="card-text">{{description}}</p>
                <p class="card-text fw-bold">RD$ {{price}}</p>
<form action="/cliente/carrito/agregar/{{../commerce._id}}" method="POST">
  <input type="hidden" name="productId" value="{{_id}}">
  <button type="submit" class="btn btn-primary btn-sm">Agregar al carrito</button>
</form>
              </div>
            </div>
          </div>
        </div>
      </div>
      {{/each}}
    </div>
  </div>
{{else}}
  <div class="alert alert-warning">No hay productos disponibles.</div>
{{/each}}

<div class="mt-4 p-3 border rounded bg-light">
  <h4>Mi Pedido</h4>
  <div id="cart-items">
    {{#if session.cart.length}}
      {{#each session.cart}}
        <div class="d-flex justify-content-between border-bottom py-1">
          <span>{{name}}</span>
          <span>RD$ {{price}}</span>
          <form action="/cliente/carrito/remover" method="POST">
            <input type="hidden" name="productId" value="{{productId}}">
            <button type="submit" class="btn btn-sm btn-danger">X</button>
          </form>
        </div>
      {{/each}}
      <div class="mt-2 fw-bold">Subtotal: RD$ {{subtotal}}</div>
      <a href="/cliente/checkout" class="btn btn-success mt-2">Continuar</a>
    {{else}}
      <p>No hay productos seleccionados</p>
    {{/if}}
  </div>
</div>