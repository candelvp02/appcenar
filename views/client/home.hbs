<div class="container">
    <h2 class="mb-4 text-center">¿Qué deseas comer hoy?</h2>
    <div class="row">
        {{#each commerceTypes}}
        <div class="col-md-3 col-sm-6 mb-4">
            <a href="/cliente/comercios/tipo/{{this._id}}" class="text-decoration-none">
                <div class="card text-center card-hover">
                    <div class="card-body">
                        <i class="fas fa-store fa-4x mb-3 text-primary"></i>
                        <h5 class="card-title">{{this.name}}</h5>
                        <p class="card-text text-muted">{{this.description}}</p>
                    </div>
                </div>
            </a>
        </div>
        {{/each}}
    </div>
</div>