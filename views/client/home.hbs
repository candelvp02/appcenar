<div class="page-header">
  <div>
    <h1 class="page-title">Hola, <span style="color:var(--orange);">{{user.name}}</span> 👋</h1>
    <p class="page-subtitle">¿Qué vas a pedir hoy?</p>
  </div>
</div>

<div class="type-grid">
  {{#each commerceTypes}}
    <a href="/client/commerces/{{_id}}" class="type-card">
      {{#if icon}}
        <img src="{{icon}}" alt="{{name}}" class="type-card-icon" />
      {{else}}
        <div class="type-card-icon-placeholder">
          <i class="bi bi-shop"></i>
        </div>
      {{/if}}
      <span class="type-card-name">{{name}}</span>
    </a>
  {{else}}
    <div class="empty-state col-span-full">
      <i class="bi bi-shop-window"></i>
      <p>No hay tipos de comercios disponibles aún.</p>
    </div>
  {{/each}}
</div>