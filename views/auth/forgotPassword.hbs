<div class="login-wrapper">
  <div class="login-card">
    <div class="login-brand text-center mb-4">
      <div class="brand-icon mb-2">
        <i class="bi bi-key-fill" style="font-size: 2.5rem; color: var(--orange);"></i>
      </div>
      <h3>Recuperar Contraseña</h3>
      <p class="text-muted">Ingresa tu usuario o correo para recibir un enlace</p>
    </div>

    {{#if error}}
      <div class="alert alert-danger mb-3"><i class="bi bi-exclamation-circle me-2"></i>{{error}}</div>
    {{/if}}

    <form action="/forgot-password" method="POST">
      <div class="mb-4">
        <label for="usernameOrEmail" class="form-label">Usuario o correo electrónico</label>
        <input type="text" class="form-control" id="usernameOrEmail" name="usernameOrEmail" placeholder="ejemplo@correo.com" required>
      </div>
      
      <div class="d-grid gap-2">
        <button type="submit" class="btn btn-danger py-2">Enviar enlace de recuperación</button>
        <a href="/login" class="btn btn-link text-decoration-none">Volver al inicio de sesión</a>
      </div>
    </form>
  </div>
</div>