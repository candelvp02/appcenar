<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow">
            <div class="card-header bg-warning">
                <h4 class="mb-0"><i class="fas fa-key"></i> Restablecer contraseña</h4>
            </div>
            <div class="card-body">
                <form action="/forgot-password" method="POST">
                    <div class="mb-3">
                        <label for="usernameOrEmail" class="form-label">Usuario o correo electrónico</label>
                        <input type="text" class="form-control" id="usernameOrEmail" name="usernameOrEmail" required>
                    </div>
                    <button type="submit" class="btn btn-warning w-100">Enviar enlace de recuperación</button>
                </form>
                <hr>
                <a href="/login" class="btn btn-link">Volver al inicio de sesión</a>
            </div>
        </div>
    </div>
</div>