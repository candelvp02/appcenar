<div class="page-header mb-4">
  <h1 class="page-title"><i class="bi bi-motorcycle"></i> Mis Pedidos Asignados</h1>
</div>

<div class="order-list">
  {{#each orders}}
    <a href="/delivery/pedido/{{_id}}" class="order-item {{status}}">
      
      {{#if commerceId.logo}}
        <img src="/uploads/{{commerceId.logo}}" style="width:48px;height:48px;border-radius:12px;object-fit:cover;flex-shrink:0;" />
      {{else}}
        <div style="width:48px;height:48px;border-radius:12px;background:#f3f4f6;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <i class="bi bi-shop" style="color:#9ca3af;"></i>
        </div>
      {{/if}}
      
      <div class="order-meta">
        <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.25rem;">
          <span class="badge bg-{{statusClass status}}">{{statusLabel status}}</span>
          <span style="color:#9ca3af;font-size:0.78rem;">{{formatDate createdAt}}</span>
        </div>
        
        <div class="order-commerce-name">{{commerceId.name}}</div>
        
        <div class="order-info">RD$ {{total}} &bull; {{items.length}} producto(s)</div>
      </div>
      <i class="bi bi-chevron-right" style="color:#d1d5db;"></i>
    </a>
  {{else}}
    <div class="alert alert-info mt-3">
      <i class="bi bi-info-circle me-2"></i>No tienes pedidos asignados actualmente.
    </div>
  {{/each}}
</div>