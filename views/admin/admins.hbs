<div class="card shadow">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h4 class="mb-0"><i class="fas fa-user-shield"></i> Administradores</h4>
        <a href="/admin/administrador/crear" class="btn btn-light btn-sm">Nuevo Administrador</a>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Apellido</th>
                        <th>Usuario</th>
                        <th>Cédula</th> <th>Email</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each admins as |admin|}}
                    <tr>
                        <td>{{admin.firstName}}</td>
                        <td>{{admin.lastName}}</td>
                        <td>{{admin.username}}</td>
                        <td>{{admin.cedula}}</td> <td>{{admin.email}}</td>
                        <td>
                            {{#if admin.isActive}}
                                <span class="badge bg-success">Activo</span>
                            {{else}}
                                <span class="badge bg-danger">Inactivo</span>
                            {{/if}}
                        </td>
<td>
    {{#ifCond admin._id '!==' @root.currentUserId}}
        <a href="/admin/administrador/editar/{{admin._id}}" class="btn btn-info btn-sm">
            <i class="fas fa-edit"></i> Editar
        </a>

        <form action="/admin/administrador/{{admin._id}}/toggle" method="POST" style="display:inline;">
            {{#if admin.isActive}}
                <button type="submit" class="btn btn-warning btn-sm" onclick="return confirm('¿Inactivar este administrador?')">
                    Inactivar
                </button>
            {{else}}
                <button type="submit" class="btn btn-success btn-sm">
                    Activar
                </button>
            {{/if}}
        </form>
    {{else}}
        <span class="badge bg-secondary p-2" style="font-size: 0.85rem;">
            <i class="fas fa-user-circle me-1"></i> Tu Cuenta
        </span>
    {{/ifCond}}
</td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    </div>
</div>