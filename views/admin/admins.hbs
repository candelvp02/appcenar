<div class="card shadow">
    <div class="card-header bg-primary text-white">
        <h4 class="mb-0"><i class="fas fa-user-shield"></i> Administradores</h4>
    </div>
    <div class="card-body">
        <a href="/admin/administrador/crear" class="btn btn-primary mb-3"><i class="fas fa-plus"></i> Nuevo Administrador</a>
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr><th>Nombre</th><th>Apellido</th><th>Usuario</th><th>Cédula</th><th>Email</th><th>Estado</th><th>Acciones</th></tr>
                </thead>
                <tbody>
                    {{#each admins}}
                    <tr>
                        <td>{{this.firstName}}</td>
                        <td>{{this.lastName}}</td>
                        <td>{{this.username}}</td>
                        <td>{{this.cedula}}</td>
                        <td>{{this.email}}</td>
                        <td>
                            {{#if this.isActive}}
                                <span class="badge bg-success">Activo</span>
                            {{else}}
                                <span class="badge bg-danger">Inactivo</span>
                            {{/if}}
                        </td>
                        <td>
                            {{#ifCond this._id '!==' ../currentUserId}}
                                <a href="/admin/administrador/editar/{{this._id}}" class="btn btn-info btn-sm">Editar</a>
                                <form action="/admin/administrador/{{this._id}}/toggle" method="POST" style="display:inline;">
                                    {{#if this.isActive}}
                                        <button type="submit" class="btn btn-warning btn-sm" onclick="return confirm('¿Desactivar este administrador?')">Inactivar</button>
                                    {{else}}
                                        <button type="submit" class="btn btn-success btn-sm" onclick="return confirm('¿Activar este administrador?')">Activar</button>
                                    {{/if}}
                                </form>
                            {{else}}
                                <span class="text-muted">(Tu usuario)</span>
                            {{/ifCond}}
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    </div>
</div>