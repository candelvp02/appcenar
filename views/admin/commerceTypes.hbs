<div class="card shadow">
    <div class="card-header bg-primary text-white">
        <h4 class="mb-0"><i class="fas fa-tags"></i> Tipos de Comercio</h4>
    </div>
    <div class="card-body">
        <a href="/admin/tipo-comercio/crear" class="btn btn-primary mb-3"><i class="fas fa-plus"></i> Nuevo Tipo</a>
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr><th>Icono</th><th>Nombre</th><th>Descripción</th><th>Comercios</th><th>Acciones</th></tr>
                </thead>
                <tbody>
                    {{#each types}}
                    <tr>
                        <td>{{#if this.icon}}<img src="/uploads/{{this.icon}}" width="40" height="40">{{else}}{{this.icon}}{{/if}}</td>
                        <td>{{this.name}}</td>
                        <td>{{this.description}}</td>
                        <td>{{this.commerceCount}}</td>
                        <td>
                            <a href="/admin/tipo-comercio/editar/{{this._id}}" class="btn btn-info btn-sm">Editar</a>
                            <a href="/admin/tipo-comercio/eliminar/{{this._id}}" class="btn btn-danger btn-sm">Eliminar</a>
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    </div>
</div>