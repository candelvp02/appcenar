<div class="card shadow">
    <div class="card-header bg-primary text-white">
        <h4 class="mb-0"><i class="fas fa-users"></i> Listado de Clientes</h4>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr><th>Nombre</th><th>Apellido</th><th>Email</th><th>Teléfono</th><th>Pedidos</th><th>Estado</th><th>Acciones</th></tr>
                </thead>
                <tbody>
                    {{#each clients}}
                    <tr>
                        <td>{{this.firstName}}</td>
                        <td>{{this.lastName}}</td>
                        <td>{{this.email}}</td>
                        <td>{{this.phone}}</td>
                        <td>{{this.orderCount}}</td>
                        <td>
                            {{#if this.isActive}}
                                <span class="badge bg-success">Activo</span>
                            {{else}}
                                <span class="badge bg-danger">Inactivo</span>
                            {{/if}}
                        </td>
                        <td>
                            <form action="/admin/cliente/{{this._id}}/toggle" method="POST" style="display:inline;">
                                {{#if this.isActive}}
                                    <button type="submit" class="btn btn-warning btn-sm" onclick="return confirm('¿Desactivar este cliente?')">Inactivar</button>
                                {{else}}
                                    <button type="submit" class="btn btn-success btn-sm" onclick="return confirm('¿Activar este cliente?')">Activar</button>
                                {{/if}}
                            </form>
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    </div>
</div>